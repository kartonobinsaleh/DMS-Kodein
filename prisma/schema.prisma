generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dailyLogs DailyLog[]
}

model Student {
  id           String        @id @default(cuid())
  name         String
  class        String
  statusToken  String        @unique @default(cuid()) // Secure link token
  createdAt    DateTime      @default(now())
  
  // V2: Ownership & Daily Logs
  ownedDevices Device[]      @relation("DeviceOwner")
  dailyLogs    DailyLog[]
}

model Device {
  id           String        @id @default(cuid())
  name         String
  type         DeviceType    @default(LAPTOP)
  status       DeviceStatus  @default(AVAILABLE)
  createdAt    DateTime      @default(now())
  
  // V2 Relations
  ownerId      String?
  owner        Student?      @relation("DeviceOwner", fields: [ownerId], references: [id])
  dailyLogs    DailyLog[]

  @@unique([ownerId, type])
}

model DailyLog {
  id           String    @id @default(cuid())
  date         DateTime  @db.Date @default(now())
  checkOutTime DateTime?
  checkInTime  DateTime?
  dailyStatus  LogStatus @default(NOT_RETURNED)
  
  studentId    String
  deviceId     String
  staffId      String?   // Last staff member who handled this log
  reason       String?   // New: Admin override reason
  
  student      Student   @relation(fields: [studentId], references: [id])
  device       Device    @relation(fields: [deviceId], references: [id])
  staff        User?     @relation(fields: [staffId], references: [id])
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([studentId, deviceId, date])
}

enum Role {
  ADMIN
  STAFF
}

enum DeviceType {
  LAPTOP
  PHONE
}

enum DeviceStatus {
  AVAILABLE
  BORROWED
  MAINTENANCE
}

enum LogStatus {
  ON_TIME
  LATE
  NOT_RETURNED
}
